{
  "name": "c64commander",
  "private": true,
  "version": "0.8.8",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "node scripts/run-vite.mjs",
    "start": "node scripts/run-vite.mjs",
    "format": "npm run format:yaml && npm run format:ts && npm run format:eslint",
    "format:yaml": "prettier --write \"**/*.{yaml,yml}\"",
    "format:ts": "prettier --write \"**/*.{ts,tsx,json}\"",
    "format:eslint": "eslint . --fix",
    "format:check": "npm run format:check:yaml && npm run format:check:ts && npm run format:check:eslint",
    "format:check:yaml": "prettier --check \"**/*.{yaml,yml}\"",
    "format:check:ts": "prettier --check \"**/*.{ts,tsx,json}\"",
    "format:check:eslint": "eslint .",
    "assets:brand": "node scripts/sync-brand-assets.mjs",
    "assets:brand:check": "node scripts/sync-brand-assets.mjs --check",
    "manuals:build": "node scripts/build-manuals.mjs",
    "agentic:mcp:setup": "node scripts/setup-agentic-mcp.mjs",
    "agentic:mcp:check": "node scripts/setup-agentic-mcp.mjs --check",
    "variant:generate": "npm run assets:brand && node scripts/generate-variant.mjs",
    "variant:check": "npm run assets:brand:check && node scripts/generate-variant.mjs --check",
    "prebuild": "{ [ -n \"${VITE_APP_VERSION:-}\" ] || bash scripts/resolve-version.sh; } && npm run variant:generate && npm run feature-flags:compile && npm run menu-mapping:compile && npm run notices:generate",
    "predev": "npm run variant:generate && npm run feature-flags:compile && npm run menu-mapping:compile",
    "prestart": "npm run variant:generate && npm run feature-flags:compile && npm run menu-mapping:compile",
    "feature-flags:compile": "node scripts/compile-feature-flags.mjs",
    "feature-flags:check": "node scripts/compile-feature-flags.mjs --check",
    "menu-mapping:compile": "node scripts/compile-menu-mapping.mjs",
    "menu-mapping:check": "node scripts/compile-menu-mapping.mjs --check",
    "postbuild": "bash scripts/package-third-party-notice.sh",
    "build": "node scripts/run-vite.mjs build",
    "build:web-server": "tsc -p web/server/tsconfig.json",
    "build:web-platform": "npm run build && npm run build:web-server",
    "build:dev": "node scripts/run-vite.mjs build --mode development",
    "lint": "npm run format:check:ts && eslint . && npm run typecheck && npm run lint:display-profiles && npm run lint:bundle-budgets && npm run lint:stale-names && npm run variant:check && npm run feature-flags:check && npm run menu-mapping:check",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint:stale-names": "node scripts/check-stale-variant-names.mjs",
    "lint:display-profiles": "node scripts/check-display-profile-breakpoints.mjs",
    "lint:bundle-budgets": "node scripts/check-bundle-budgets.mjs --skip-if-missing",
    "postinstall": "patch-package && node --input-type=module -e \"import { existsSync } from 'node:fs'; import { execFileSync } from 'node:child_process'; if (existsSync('./c64scope/package.json')) execFileSync('npm', ['install', '--prefix', 'c64scope'], { stdio: 'inherit' }); if (existsSync('./scripts/install-git-hooks.mjs')) await import('./scripts/install-git-hooks.mjs');\"",
    "preview": "node scripts/run-vite.mjs preview",
    "start:web": "node web/server/dist/index.js",
    "test": "vitest run",
    "test:web-server": "vitest run tests/unit/web/webServer.test.ts",
    "test:web-platform": "npm run test:web-server",
    "test:watch": "vitest",
    "test:coverage": "node scripts/run-unit-coverage.mjs",
    "coverage:gate": "npm run test:coverage:all && COVERAGE_MIN=91 COVERAGE_MIN_BRANCH=91 COVERAGE_FILE=coverage/lcov-merged.info node scripts/check-coverage-threshold.mjs",
    "test:agents": "bash -c 'if [ -f .venv/bin/python3 ]; then PYTHON=$(pwd)/.venv/bin/python3; else PYTHON=python3; fi; cd agents && $PYTHON -m pytest --cov=openhands --cov-branch --cov-report=term-missing --cov-report=xml:coverage-agents.xml tests/'",
    "test:coverage:all": "./scripts/collect-coverage.sh",
    "perf:prepare:archives": "node scripts/hvsc/prepare-perf-archives.mjs --out=ci-artifacts/hvsc-performance/archive-preparation.json",
    "test:perf": "npm run test:perf:smoke && npm run test:perf:secondary:smoke && npm run test:perf:node:smoke",
    "test:perf:quick": "npm run test:perf:smoke",
    "test:perf:smoke": "HVSC_PERF_PROFILE=smoke node scripts/hvsc/collect-web-perf.mjs --suite=scenarios",
    "test:perf:nightly": "if [ -z \"${HVSC_PERF_ARCHIVE_METADATA_FILE:-}\" ]; then npm run perf:prepare:archives; fi && HVSC_PERF_PROFILE=${HVSC_PERF_PROFILE:-nightly} HVSC_PERF_USE_REAL_ARCHIVES=1 HVSC_PERF_BYTES_PER_SECOND=5242880 node scripts/hvsc/collect-web-perf.mjs --suite=scenarios",
    "test:perf:secondary:quick": "npm run test:perf:secondary:smoke",
    "test:perf:secondary:smoke": "HVSC_PERF_PROFILE=smoke node scripts/hvsc/collect-web-perf.mjs --suite=secondary",
    "test:perf:secondary:nightly": "if [ -z \"${HVSC_PERF_ARCHIVE_METADATA_FILE:-}\" ]; then npm run perf:prepare:archives; fi && HVSC_PERF_PROFILE=${HVSC_PERF_PROFILE:-nightly} HVSC_PERF_USE_REAL_ARCHIVES=1 HVSC_PERF_BYTES_PER_SECOND=5242880 node scripts/hvsc/collect-web-perf.mjs --suite=secondary",
    "test:perf:node:smoke": "HVSC_PERF_PROFILE=smoke npx vite-node --script scripts/hvsc/collect-node-perf.ts",
    "test:perf:node:nightly": "HVSC_PERF_PROFILE=${HVSC_PERF_PROFILE:-nightly} npx vite-node --script scripts/hvsc/collect-node-perf.ts",
    "test:perf:assert:web": "node scripts/hvsc/assert-web-perf-budgets.mjs",
    "test:perf:assert:android": "node scripts/hvsc/assert-android-perf-budgets.mjs",
    "test:bench": "vitest bench tests/benchmarks/hvscHotPaths.bench.ts --project unit-node --run",
    "test:bench:streams": "vitest bench tests/benchmarks/streamHotPaths.bench.ts --project unit-node --run",
    "test:perf:streams": "node scripts/assert-stream-perf.mjs",
    "test:e2e": "TRACE_ASSERTIONS_DEFAULT=1 playwright test --grep-invert \"@screenshots|@web-platform\"",
    "test:device-switch-soak": "node scripts/run-device-switch-soak.mjs --target=mock",
    "test:e2e:native": "npm run maestro:gating",
    "screenshots": "node scripts/run-screenshots-with-prune.mjs",
    "screenshots:raw": "TRACE_ASSERTIONS_DEFAULT=1 PLAYWRIGHT_TRACE_MODE=off PLAYWRIGHT_VIDEO_MODE=off playwright test --grep @screenshots --workers 1",
    "screenshots:prune-identical": "node scripts/revert-identical-pngs.mjs",
    "video": "TRACE_ASSERTIONS_DEFAULT=1 playwright test --grep @video",
    "validate:evidence": "node scripts/validate-playwright-evidence.mjs",
    "validate:traces": "node scripts/compare-traces.mjs",
    "validate:evidence:android": "node scripts/validate-android-emulator-evidence.mjs",
    "test:e2e:ci": "npm run screenshots && npm run test:e2e && npm run validate:evidence && npm run validate:traces",
    "test:ci": "npm run format:check && npm run test:coverage && npm run test:e2e:ci && npm run build",
    "fuzz": "node scripts/run-fuzz.mjs",
    "proxy": "node proxy/server.mjs",
    "dev:proxy": "npm run proxy",
    "cap:init": "cap init \"C64 Commander\" \"uk.gleissner.c64commander\" --web-dir dist",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "cap:sync": "cap sync",
    "cap:sync:ios": "cap sync ios",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "cap:build": "npm run build && cap sync",
    "ios:build:sim": "bash scripts/ios-build.sh sim",
    "ios:build:device": "bash scripts/ios-build.sh device",
    "android:apk": "cd android && ./gradlew assembleDebug",
    "android:apk:all": "node scripts/build-android-apks.mjs",
    "apk:metadata": "node scripts/verify-apk-metadata.mjs",
    "apk:no-gms": "node scripts/verify-apk-no-gms.mjs",
    "test:waydroid:preflight": "bash scripts/waydroid-smoke.sh preflight",
    "test:waydroid": "bash scripts/waydroid-smoke.sh run",
    "maestro:gating": "bash scripts/run-maestro-gating.sh",
    "assets:play": "node scripts/generate-play-assets.mjs",
    "fixtures:local-source": "node scripts/generate-local-source-fixtures.mjs",
    "docker:web:build": "docker build -f web/Dockerfile -t c64commander:local .",
    "docker:web:run": "docker run --rm -p 8064:8064 -v $(pwd)/.tmp/web-config:/config c64commander:local",
    "startup:baseline": "node scripts/startup/collect-android-startup-baseline.mjs",
    "startup:gate": "node scripts/startup/assert-startup-budgets.mjs --file=ci-artifacts/startup/startup-baseline.json",
    "startup:gate:hvsc": "node scripts/startup/assert-hvsc-startup-safety.mjs --file=ci-artifacts/startup/startup-baseline.json",
    "prove:screen-snapshot-restore": "npx --yes vite-node scripts/prove-screen-snapshot-restore.ts",
    "notices:generate": "node scripts/generate-third-party-notices.mjs",
    "notices:check": "node scripts/generate-third-party-notices.mjs --check",
    "scope:build": "cd c64scope && npm run build",
    "scope:test": "cd c64scope && npm run test",
    "scope:test:coverage": "cd c64scope && npm run test:coverage",
    "scope:check": "cd c64scope && npm run check",
    "scope:cta": "cd c64scope && npm run build && npm run cta --",
    "scope:cta:discover": "cd c64scope && npm run build && npm run cta:discover --",
    "scope:cta:discover-routes": "cd c64scope && npm run build && npm run cta:discover-routes --",
    "scope:cta:gate3": "cd c64scope && npm run build && npm run cta:gate3 --",
    "scope:cta:gate4": "cd c64scope && npm run build && npm run cta:gate4 --",
    "scope:cta:gate5": "cd c64scope && npm run build && npm run cta:gate5 --",
    "scope:cta:gate6": "cd c64scope && npm run build && npm run cta:gate6 --",
    "scope:cta:gate65": "cd c64scope && npm run build && npm run cta:gate65 --",
    "scope:cta:gate7": "cd c64scope && npm run build && npm run cta:gate7 --",
    "scope:cta:keypad": "cd c64scope && npm run build && npm run cta:keypad --",
    "scope:cta:replay": "cd c64scope && npm run build && npm run cta:replay --",
    "scope:cta:resume": "cd c64scope && npm run build && npm run cta:resume --",
    "scope:full-coverage": "cd c64scope && npm run full-coverage:execute",
    "scope:hil:playback-volume-latency": "cd c64scope && npm run build && npm run hil:playback-volume-latency --",
    "scope:mcp": "cd c64scope && npm run mcp",
    "scope:preflight": "node c64scope/dist/preflight.js",
    "scope:hil:evidence": "cd c64scope && npm run hil:evidence --"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/screen-orientation": "^8.0.1",
