    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-aspect-ratio": "^1.1.11",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-hover-card": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-menubar": "^1.1.20",
    "@radix-ui/react-navigation-menu": "^1.2.18",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toast": "^1.2.19",
    "@radix-ui/react-toggle": "^1.1.14",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tanstack/react-query": "^5.101.2",
    "@types/suncalc": "^1.9.2",
    "7z-wasm": "^1.2.0",
    "baseline-browser-mapping": "^2.10.43",
    "basic-ftp": "^6.0.1",
    "caniuse-lite": "^1.0.30001806",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.6.0",
    "fflate": "^0.8.3",
    "framer-motion": "^12.42.2",
    "input-otp": "^1.4.2",
    "js-yaml": "^4.3.0",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.2",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.81.0",
    "react-resizable-panels": "^2.1.9",
    "react-router-dom": "^6.30.4",
    "react-virtuoso": "^4.18.10",
    "recharts": "^2.15.4",
    "sonner": "^1.7.4",
    "spark-md5": "^3.0.2",
    "suncalc": "^2.0.1",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^0.9.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.13.3",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "@vitest/coverage-v8": "^3.2.7",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.5.4",
    "axios": "^1.18.1",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "ftpd": "0.2.16",
    "globals": "^15.15.0",
    "jsdom": "^29.1.1",
    "lcov-result-merger": "^5.0.1",
    "marked": "^18.0.6",
    "nextcov": "^1.5.1",
    "nyc": "^18.0.0",
    "openapi-client-axios": "^7.9.0",
    "patch-package": "^8.0.1",
    "pixelmatch": "^7.2.0",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "react-test-renderer": "^18.3.1",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.4.3",
    "vite-plugin-istanbul": "^7.2.1",
    "vitest": "^3.2.4"
  },
  "overrides": {
