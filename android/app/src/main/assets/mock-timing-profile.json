{
    "version": 1,
    "seed": 19,
    "defaultClassId": "default",
    "faults": {
        "slowExtraDelayMs": 180,
        "slowJitterRangeMs": 70,
        "timeoutMinimumDelayMs": 1500
    },
    "classes": {
        "optionsProbe": {
            "baseDelayMs": 180,
            "jitterRangeMs": 18,
            "jitterSeed": 11
        },
        "probe": {
            "baseDelayMs": 9,
            "jitterRangeMs": 12,
            "jitterSeed": 1
        },
        "configRead": {
            "baseDelayMs": 13,
            "jitterRangeMs": 22,
            "jitterSeed": 2
        },
        "configWrite": {
            "baseDelayMs": 24,
            "jitterRangeMs": 18,
            "jitterSeed": 3
        },
        "machineControl": {
            "baseDelayMs": 22,
            "jitterRangeMs": 14,
            "jitterSeed": 4
        },
        "memoryRead": {
            "baseDelayMs": 9,
            "jitterRangeMs": 10,
            "jitterSeed": 5
        },
        "memoryWrite": {
            "baseDelayMs": 18,
            "jitterRangeMs": 12,
            "jitterSeed": 6
        },
        "driveListRead": {
            "baseDelayMs": 16,
            "jitterRangeMs": 7,
            "jitterSeed": 7
        },
        "driveMountPut": {
            "baseDelayMs": 744,
            "jitterRangeMs": 21,
            "jitterSeed": 12
        },
        "driveMountPost": {
            "baseDelayMs": 1110,
            "jitterRangeMs": 30,
            "jitterSeed": 13
        },
        "driveReset": {
            "baseDelayMs": 20,
            "jitterRangeMs": 6,
            "jitterSeed": 14
        },
        "driveRemove": {
            "baseDelayMs": 110,
            "jitterRangeMs": 12,
            "jitterSeed": 15
        },
        "drivePower": {
            "baseDelayMs": 10,
            "jitterRangeMs": 4,
            "jitterSeed": 16
        },
        "driveLoadRomPut": {
            "baseDelayMs": 56,
            "jitterRangeMs": 10,
            "jitterSeed": 17
        },
        "driveLoadRomPost": {
            "baseDelayMs": 68,
            "jitterRangeMs": 10,
            "jitterSeed": 18
        },
        "driveSetMode": {
            "baseDelayMs": 112,
            "jitterRangeMs": 12,
            "jitterSeed": 19
        },
        "runner": {
            "baseDelayMs": 30,
            "jitterRangeMs": 20,
            "jitterSeed": 8
        },
        "streamControl": {
            "baseDelayMs": 22,
            "jitterRangeMs": 14,
            "jitterSeed": 9
        },
        "default": {
            "baseDelayMs": 18,
            "jitterRangeMs": 14,
            "jitterSeed": 10
        }
    },
    "rules": [
        {
            "methods": [
                "OPTIONS"
            ],
            "pathType": "prefix",
            "path": "/",
            "timingClass": "optionsProbe"
        },
        {
            "methods": [
                "GET"
            ],
            "pathType": "exact",
            "path": "/v1/info",
            "timingClass": "probe"
        },
        {
            "methods": [
                "GET"
            ],
            "pathType": "exact",
            "path": "/v1/version",
            "timingClass": "probe"
        },
        {
            "methods": [
                "GET"
            ],
            "pathType": "exact",
            "path": "/v1/configs",
            "timingClass": "configRead"
        },
        {
            "methods": [
                "POST"
            ],
            "pathType": "exact",
            "path": "/v1/configs",
            "timingClass": "configWrite"
        },
        {
            "methods": [
                "GET"
            ],
            "pathType": "prefix",
            "path": "/v1/configs/",
            "timingClass": "configRead"
        },
        {
            "methods": [
                "PUT"
            ],
            "pathType": "prefix",
            "path": "/v1/configs/",
            "timingClass": "configWrite"
        },
        {
            "methods": [
                "PUT"
            ],
            "pathType": "prefix",
            "path": "/v1/configs:",
            "timingClass": "configWrite"
        },
        {
            "methods": [
                "GET"
            ],
            "pathType": "exact",
            "path": "/v1/drives",
            "timingClass": "driveListRead"
        },
        {
            "methods": [
                "PUT"
            ],
            "pathType": "regex",
            "path": "^/v1/drives/[^/]+:mount$",
            "timingClass": "driveMountPut"
        },
        {
            "methods": [
                "POST"
            ],
            "pathType": "regex",
            "path": "^/v1/drives/[^/]+:mount$",
            "timingClass": "driveMountPost"
        },
        {
            "methods": [
                "PUT"
            ],
            "pathType": "regex",
            "path": "^/v1/drives/[^/]+:reset$",
            "timingClass": "driveReset"
        },
        {
            "methods": [
                "PUT"
            ],
            "pathType": "regex",
            "path": "^/v1/drives/[^/]+:remove$",
            "timingClass": "driveRemove"
        },
        {
            "methods": [
                "PUT"
            ],
            "pathType": "regex",
            "path": "^/v1/drives/[^/]+:(on|off)$",
            "timingClass": "drivePower"
        },
        {
            "methods": [
                "PUT"
            ],
            "pathType": "regex",
            "path": "^/v1/drives/[^/]+:load_rom$",
            "timingClass": "driveLoadRomPut"
        },
        {
            "methods": [
                "POST"
            ],
            "pathType": "regex",
            "path": "^/v1/drives/[^/]+:load_rom$",
            "timingClass": "driveLoadRomPost"
        },
        {
            "methods": [
                "PUT"
            ],
            "pathType": "regex",
            "path": "^/v1/drives/[^/]+:set_mode$",
            "timingClass": "driveSetMode"
        },
        {
            "methods": [
                "PUT",
                "POST"
            ],
            "pathType": "prefix",
            "path": "/v1/runners:",
            "timingClass": "runner"
        },
        {
            "methods": [
                "GET"
            ],
            "pathType": "exact",
            "path": "/v1/machine:readmem",
            "timingClass": "memoryRead"
        },
        {
            "methods": [
                "PUT",
                "POST"
            ],
            "pathType": "exact",
            "path": "/v1/machine:writemem",
            "timingClass": "memoryWrite"
        },
        {
            "methods": [
                "PUT"
            ],
            "pathType": "prefix",
            "path": "/v1/machine:",
            "timingClass": "machineControl"
        },
        {
            "methods": [
                "PUT"
            ],
            "pathType": "prefix",
            "path": "/v1/streams/",
            "timingClass": "streamControl"
        }
    ]
}
