{
  "servers": {
    "mobile-mcp": { "type": "stdio", "command": "npx", "args": ["-y", "@mobilenext/mobile-mcp@latest"] },
    "droidmind": {
      "type": "stdio",
      "command": "uvx",
      "args": ["--from", "git+https://github.com/hyperb1iss/droidmind", "droidmind", "--transport", "stdio"]
    },
    "c64bridge": { "type": "stdio", "command": "npx", "args": ["-y", "c64bridge@latest"] },
    "c64scope": { "type": "stdio", "command": "node", "args": ["c64scope/scripts/start.mjs"] }
  }
}
