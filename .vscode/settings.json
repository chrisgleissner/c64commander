{
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always"
  },
  "editor.formatOnSave": true,
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
  "files.insertFinalNewline": true,
  "files.associations": {
    "*.yaml": "yaml",
    "*.yml": "yaml",
    ".github/workflows/*.yaml": "yaml",
    ".github/workflows/*.yml": "yaml",
    "**/.github/workflows/*.yaml": "yaml",
    "**/.github/workflows/*.yml": "yaml"
  },
  "files.exclude": {
    ".tmp": true,
    "artifacts": true,
    "ci-artifacts": true,
    "coverage": true,
    "playwright-report": true,
    "playwright-report-coverage": true,
    "test-results": true,
    "android/app/build": true,
    "android/build": true,
    "c64scope/artifacts": true,
    "1541ultimate": true,
    "android-mcp-server": true,
    "c64bridge": true,
    "c64stream": true,
    "droidmind": true,
    "mobile-mcp": true,
    "test-data": true,
    "vivipi": true
  },
  "search.exclude": {
    "**/.tmp/**": true,
    "**/artifacts/**": true,
    "**/ci-artifacts/**": true,
    "**/coverage/**": true,
    "**/playwright-report/**": true,
    "**/playwright-report-coverage/**": true,
    "**/test-results/**": true,
    "**/android/**/build/**": true,
    "**/c64scope/**/artifacts/**": true,
    "**/c64scope/**/dist/**": true,
    "1541ultimate/**": true,
    "android-mcp-server/**": true,
    "c64bridge/**": true,
    "c64stream/**": true,
    "droidmind/**": true,
    "mobile-mcp/**": true,
    "test-data/**": true,
    "vivipi/**": true
  },
  "files.watcherExclude": {
    "**/.tmp/**": true,
    "**/artifacts/**": true,
    "**/ci-artifacts/**": true,
    "**/coverage/**": true,
    "**/playwright-report/**": true,
    "**/playwright-report-coverage/**": true,
    "**/test-results/**": true,
    "**/android/**/build/**": true,
    "**/c64scope/**/artifacts/**": true,
    "**/c64scope/**/dist/**": true,
    "1541ultimate/**": true,
    "android-mcp-server/**": true,
    "c64bridge/**": true,
    "c64stream/**": true,
    "droidmind/**": true,
    "mobile-mcp/**": true,
    "test-data/**": true,
    "vivipi/**": true
  },
  "files.trimTrailingWhitespace": true,
  "prettier.requireConfig": true,
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.import.gradle.enabled": true,
  "java.import.gradle.wrapper.enabled": true,
  "java.project.sourcePaths": [
    "android/app/src/main/java",
    "android/app/src/test/java",
    "android/app/src/androidTest/java"
  ],
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": true
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": true
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[kotlin]": {
    "editor.formatOnSave": true,
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "vitest.configFile": "vitest.config.ts",
  "bun.test.enable": false,
  "terminal.integrated.defaultProfile.linux": "bash-clean",
  "terminal.integrated.profiles.linux": {
    "bash-clean": {
      "path": "/usr/bin/bash"
    }
  },
  "terminal.integrated.automationProfile.linux": {
    "path": "/bin/sh"
  },
  "terminal.integrated.enablePersistentSessions": false
}
