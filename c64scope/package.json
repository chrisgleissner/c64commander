{
  "name": "c64scope",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Physical-evidence MCP server for autonomous C64 Commander hardware testing",
  "license": "GPL-3.0-or-later",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=10"
  },
  "bin": {
    "c64scope": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run build && npm run test",
    "cta:discover": "node dist/ctaDiscover.js",
    "explore:wave1": "node dist/agenticExploratoryWave1.js",
    "full-coverage:execute": "node dist/fullAppCoverageExecutor.js",
    "hil:evidence": "node dist/hilEvidenceRun.js",
    "hil:playback-volume-latency": "node dist/playbackVolumeLatency.js",
    "mcp": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  }
}
